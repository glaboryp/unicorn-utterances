---
import type { QuizRadioInlineProps } from "#components/quiz-radio/quiz-radio-inline.tsx";
import { QuizRadioInline as PreactQuizRadio } from "#components/quiz-radio/quiz-radio-inline.tsx";
import type { PlayfulNode } from "../components.ts";
import Content from "../content.astro";

export type Props = QuizRadioInlineProps & { children: PlayfulNode[] };
const { children, ...props } = Astro.props;
---

{
	children.length ? (
		<PreactQuizRadio {...props} client:load>
			<Content content={children} />
		</PreactQuizRadio>
	) : (
		<PreactQuizRadio {...props} client:load />
	)
}
