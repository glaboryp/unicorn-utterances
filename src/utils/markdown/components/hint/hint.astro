---
import { Hint as PreactHint } from "#components/hint/hint.tsx";
import type { ComponentNode } from "../components.ts";
import Content from "../content.astro";

export interface Props {
	title: string;
	children: ComponentNode["children"];
}
---

<PreactHint title={Astro.props.title}>
	<Content content={Astro.props.children} />
</PreactHint>
